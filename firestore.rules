rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 檢查是否為超級管理員
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'SUPER_ADMIN';
    }
    
    // 檢查是否為該機構的管理員 (orgId 必須存在於使用者的 org_ids 陣列中)
    function isOrgAdmin(orgId) {
      return request.auth != null && 
             (request.auth.token.role == 'ORG_ADMIN' || request.auth.token.role == 'SUPER_ADMIN') && 
             (orgId in request.auth.token.org_ids || isSuperAdmin());
    }

    // ==========================================
    // Users 集合
    // ==========================================
    match /users/{userId} {
      // 任何人登入後都可以讀取其他使用者的基本資料 (為了讓超級管理員在列表看到他們)
      allow read: if request.auth != null;
      // 只有超級管理員可以修改用戶權限，或是用戶自己可以修改自己的資料
      allow write: if isSuperAdmin() || request.auth.uid == userId;
    }

    // ==========================================
    // Organizations 集合
    // ==========================================
    match /organizations/{orgId} {
      // 超級管理員可以讀寫所有機構
      allow read, write: if isSuperAdmin();
      // 單位管理員只能讀取與修改自己的機構資料
      allow read, update: if isOrgAdmin(orgId);
    }

    // ==========================================
    // Elections 集合與其所有子集合 (candidates, items, rounds 等)
    // ==========================================
    match /elections/{electionId} {
      // 允許公開讀取選舉資訊 (給投影機與選民)
      allow read: if true;
      allow write: if isSuperAdmin() || isOrgAdmin(resource.data.org_id);
      allow create: if isSuperAdmin() || isOrgAdmin(request.resource.data.org_id);
      
      match /keys/{keyId} {
        allow read: if true;
        allow update: if true; // 允許選民更新金鑰狀態
        allow write: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/elections/$(electionId)).data.org_id);
      }
      
      match /votes/{voteId} {
        allow read: if true;
        allow create: if true; // 允許選民寫入選票
        allow write: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/elections/$(electionId)).data.org_id);
      }

      // 遞迴允許所有子集合存取 (繼承父選舉的權限)
      match /{document=**} {
        allow read: if true; // 允許公開讀取 (候選人、輪次、項次等)
        allow write: if isSuperAdmin() || isOrgAdmin(get(/databases/$(database)/documents/elections/$(electionId)).data.org_id);
      }
    }
  }
}
